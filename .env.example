# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://mfefumwjzbzuqfyvpoeo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Prisma — connection pooler (porta 6543) para queries em runtime
DATABASE_URL=postgresql://postgres:PASSWORD@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Prisma — conexão direta (porta 5432) para migrations
DIRECT_URL=postgresql://postgres:PASSWORD@db.mfefumwjzbzuqfyvpoeo.supabase.co:5432/postgres

# ─────────────────────────────────────────────
# Mercado Pago
# ─────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=your_access_token_here
MERCADOPAGO_WEBHOOK_SECRET=your_webhook_secret_here

# ─────────────────────────────────────────────
# Resend (e-mail transacional)
# ─────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@revistamagnum.com.br

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://revistamagnum.com.br
